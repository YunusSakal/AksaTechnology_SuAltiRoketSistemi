<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Aksa Technology</title>
    <link rel="stylesheet" href="~/css/rdash.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)

    <style>
        html,
        body {
            min-height: 100%;
            margin: 0;
        }

        body {
            min-height: 100vh;
            background: #080d1c;
        }

        .topbar {
            height: 64px;
        }

        .app-shell {
            display: flex;
            min-height: calc(100vh - 64px);
            align-items: stretch;
        }

        .sidebar {
            min-height: calc(100vh - 64px);
            height: calc(100vh - 64px);
            display: flex;
            flex-direction: column;
            align-self: stretch;
            overflow: hidden;
        }
        
        .sidebar-logo {
            flex: 0 0 auto;
        }

        .nav-links {
            flex: 1 1 auto;
            margin: 0;
            overflow-y: auto;
        }

        .sidebar-footer {
            flex: 0 0 58px;
            min-height: 58px;
            padding: 0 18px;
            border-top: 1px solid rgba(73, 166, 255, 0.12);
            display: flex;
            align-items: center;
            justify-content: flex-start;
            background: rgba(8, 13, 28, 0.22);
        }

        .footer-time {
            color: #ffffff;
            font-size: 0.95rem;
            font-weight: 700;
            letter-spacing: 1.2px;
            line-height: 1;
        }

        .main-content {
            flex: 1 1 auto;
            min-height: calc(100vh - 64px);
        }

            /* Responsive adjustments */
        .sidebar.collapsed {
            width: 76px !important;
            min-width: 76px !important;
            max-width: 76px !important;
        }

        .sidebar.collapsed .sidebar-logo {
            justify-content: center;
            padding-left: 0;
            padding-right: 0;
        }

        .sidebar.collapsed .sidebar-logo span {
            display: none;
        }

        .sidebar.collapsed .sidebar-logo-icon {
            margin: 0 auto;
        }

        .sidebar.collapsed .nav-section-label {
            display: none;
        }

        .sidebar.collapsed .nav-link {
            justify-content: center;
            padding-left: 0;
            padding-right: 0;
            gap: 0;
        }

        .sidebar.collapsed .nav-link svg {
            margin: 0;
            flex-shrink: 0;
        }

        .sidebar.collapsed .nav-link {
            font-size: 0;
        }

        .sidebar.collapsed .sidebar-footer {
            justify-content: center;
            padding-left: 0;
            padding-right: 0;
        }

        .sidebar.collapsed .footer-time {
            display: none;
        }
    </style>
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    <!-- ===== TOP NAV BAR ===== -->
    <header class="topbar">
        <div class="topbar-left">
            <button class="sidebar-toggle" id="sidebarToggle" aria-label="Menü">
                <span></span><span></span><span></span>
            </button>
            <span class="brand-name">Aksa<span class="brand-accent">Technology</span></span>
        </div>

        <div class="topbar-right">
            <span class="status-pill" id="statusPill">
                <span class="status-dot"></span> Sistem Aktif
            </span>

            <span class="user-badge">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="8" r="4" />
                    <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                </svg>

                @User.Identity.Name

                @if (User.IsInRole("Admin"))
                {
                    <span class="role-chip admin">ADMİN</span>
                }
                else
                {
                    <span class="role-chip user">KULLANICI</span>
                }
            </span>

            <a href="/Account/Cikis" class="btn-danger-sm">Çıkış</a>
        </div>
    </header>

    <div class="app-shell">
        <!-- ===== SIDEBAR ===== -->
        <nav class="sidebar" id="sidebar">
            <div class="sidebar-logo">
                <div class="sidebar-logo-icon">
                    <img src="~/img/logo.png" alt="Aksa Logo" class="login-sidebar-logo" />
                </div>
                <span>Sualtı Roket Sistemi</span>
            </div>

            <ul class="nav-links">
                <li class="nav-section-label">GENEL</li>

                <li>
                    <a asp-page="/Dashboard/Index" class="nav-link @(ViewData["ActivePage"]?.ToString() == "dashboard" ? "active" : "")">
                        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <rect x="3" y="3" width="7" height="7" rx="1" />
                            <rect x="14" y="3" width="7" height="7" rx="1" />
                            <rect x="3" y="14" width="7" height="7" rx="1" />
                            <rect x="14" y="14" width="7" height="7" rx="1" />
                        </svg>
                        Ana Panel
                    </a>
                </li>

                <li>
                    <a asp-page="/Telemetri/Index" class="nav-link @(ViewData["ActivePage"]?.ToString() == "telemetri" ? "active" : "")">
                        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                        </svg>
                        IMU Telemetri
                    </a>
                </li>

                <li>
                    <a asp-page="/Telemetri/GecmisVeri" class="nav-link @(ViewData["ActivePage"]?.ToString() == "gecmis" ? "active" : "")">
                        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" />
                            <polyline points="12 6 12 12 16 14" />
                        </svg>
                        Geçmiş Veriler
                    </a>
                </li>

                <li class="nav-section-label">OPERASYON</li>

                <li>
                    <a asp-page="/Gorevler/Index" class="nav-link @(ViewData["ActivePage"]?.ToString() == "gorevler" ? "active" : "")">
                        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M9 11l3 3L22 4" />
                            <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" />
                        </svg>
                        Görevler
                    </a>
                </li>

                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-section-label">YÖNETİM</li>

                    <li>
                        <a asp-page="/Kullanicilar/Index" class="nav-link @(ViewData["ActivePage"]?.ToString() == "kullanicilar" ? "active" : "")">
                            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                                <circle cx="9" cy="7" r="4" />
                                <path d="M23 21v-2a4 4 0 00-3-3.87" />
                                <path d="M16 3.13a4 4 0 010 7.75" />
                            </svg>
                            Kullanıcılar
                        </a>
                    </li>
                }
            </ul>

            <div class="sidebar-footer">
                <span class="footer-time" id="footerClock"></span>
            </div>
        </nav>

        <!-- ===== MAIN CONTENT ===== -->
        <main class="main-content">
            @RenderBody()
        </main>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)

<script>
    function updateClock() {
        const now = new Date();
        const el = document.getElementById('footerClock');

        if (el) {
            el.textContent = now.toLocaleTimeString('tr-TR');
        }
    }

    updateClock();
    setInterval(updateClock, 1000);

    document.getElementById('sidebarToggle')?.addEventListener('click', function () {
        document.getElementById('sidebar')?.classList.toggle('collapsed');
        document.querySelector('.main-content')?.classList.toggle('expanded');
    });
</script>
</body>
</html>